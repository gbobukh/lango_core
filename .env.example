# Copy to .env and adjust. Never commit .env.

# Load ``lango_core/settings/local.py`` (paths, dev-only knobs). Omit on production.
# LANGO_USE_LOCAL_SETTINGS=1

# Required for production / shared hosts. Locally you may omit this line entirely,
# or leave blank — settings fall back to an insecure dev key if unset or empty.
# SECRET_KEY=

# 1/true/yes = DEBUG on (default if unset). 0/false/no = production-style flags.
DEBUG=1

# Comma-separated. If unset, defaults match previous lango_core behavior.
# ALLOWED_HOSTS=core.lango.media,www.core.lango.media

# Extra CSRF trusted origins (comma-separated), appended to built-in lists.
# CSRF_TRUSTED_ORIGINS_EXTRA=http://127.0.0.1:8001

# 1 = force HTTPS redirects (when DEBUG=0, defaults to on unless set to 0).
# SECURE_SSL_REDIRECT=1

# collectstatic target. Default: <repo>/staticfiles
# STATIC_ROOT=/var/www/lango_core_static

# Uploaded files (API specs, etc.). Default: <repo>/media
# MEDIA_ROOT=/var/www/lango_core_media

# Redis for API rate limits (optional; limiter fails open if unavailable).
# REDIS_URL=redis://127.0.0.1:6379/0

# When prod and staging share one user crontab and Redis on the same host, set a unique value
# per deployment (e.g. prod / staging). Cron comments and workflow locks include it. Not secret.
# Omit for local single-env (defaults to prod in settings).
# SCHEDULER_NAMESPACE=prod
