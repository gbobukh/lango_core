# HTTP server - Cloudflare handles SSL
server {
    server_name core.lango.media www.core.lango.media;

    # Логирование
    access_log /var/log/nginx/core.lango.media.access.log;
    error_log /var/log/nginx/core.lango.media.error.log;

    # Максимальный размер загружаемых файлов
    client_max_body_size 100M;

    # Проксирование к Django серверу на порту 8002
    location / {
        proxy_pass http://127.0.0.1:8002;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        
        # Cloudflare headers
        proxy_set_header CF-Connecting-IP $http_cf_connecting_ip;
        proxy_set_header CF-Visitor $http_cf_visitor;
        proxy_set_header CF-Ray $http_cf_ray;
        proxy_set_header CF-Country $http_cf_country;
        
        # Origin header для CSRF
        proxy_set_header Origin $scheme://$host;
        
        # Таймауты (5 min для длинных workflow)
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
        
        # Буферизация
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
    }

    # Статические файлы Django
    location /static/ {
        alias /var/www/lango_core_static/;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Медиа файлы (если есть)
    location /media/ {
        alias /root/lango_core/media/;
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Безопасность
    location ~ /\. {
        deny all;
    }

    listen 80;
    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/api-gate.online/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api-gate.online/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}
